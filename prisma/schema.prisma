generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  RESELLER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum UserTier {
  RESELLER
  AGEN
  MASTER_DEALER
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductCategory {
  // ── Prabayar ──
  PULSA
  DATA
  GAMES
  VOUCHER
  EMONEY
  TOKEN_PLN
  PAKET_SMS_TELPON
  AKTIVASI_VOUCHER
  TV_PRABAYAR
  MASA_AKTIF
  AKTIVASI_PERDANA
  MEDIA_SOSIAL
  ESIM
  GAS
  HAYAKA_TOPUP
  CHINA_TOPUP
  VIETNAM_TOPUP
  THAILAND_TOPUP
  PHILIPPINES_TOPUP
  SRILANKA_TOPUP
  BUNDLING
  // ── Pascabayar ──
  PLN_PASCABAYAR
  PDAM
  HP_PASCABAYAR
  INTERNET_PASCABAYAR
  BPJS_KESEHATAN
  MULTIFINANCE
  PBB
  GAS_NEGARA
  TV_PASCABAYAR
  BPJS_KETENAGAKERJAAN
  PLN_NONTAGLIS
  EMONEY_PASCABAYAR
  TELKOM_INDIHOME
  INDOSAT_PASCABAYAR
  TRI_PASCABAYAR
  // ── Legacy (tetap ada agar data lama tidak error) ──
  GAME
  LAINNYA
}

enum NotificationType {
  TRANSACTION_SUCCESS
  TRANSACTION_FAILED
  DEPOSIT_APPROVED
  DEPOSIT_REJECTED
  LOW_BALANCE_ALERT
  REFUND
  SYSTEM
  PROMO
}

model User {
  id            String     @id @default(uuid())
  name          String
  phone         String     @unique
  email         String     @unique
  passwordHash  String     @map("password_hash")
  pinHash       String?    @map("pin_hash")
  role          Role       @default(RESELLER)
  tier          UserTier   @default(RESELLER)
  status        UserStatus @default(PENDING)
  points        Int        @default(0)
  referralCode  String?    @unique @map("referral_code")
  referredBy    String?    @map("referred_by")
  resetToken    String?    @map("reset_token")
  resetTokenExp DateTime?  @map("reset_token_exp")
  currentSessionId String? @map("current_session_id")
  
  provinsi      String?
  kabupaten     String?
  kecamatan     String?
  alamat        String?
  storeName     String?    @map("store_name")
  otpCode       String?    @map("otp_code")
  otpExp        DateTime?  @map("otp_exp")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  wallet        Wallet?
  transactions  Transaction[]
  deposits      Deposit[]
  notifications Notification[]
  pointLedger     PointLedger[]
  favoriteNumbers FavoriteNumber[]
  catatan         Catatan[]
  kasirSessions   KasirSession[]
  devices         UserDevice[]

  maxDevices      Int        @default(1) @map("max_devices")
  deviceRequest   Int?       @map("device_request")

  @@map("users")
}

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  balanceHold Decimal  @default(0) @map("balance_hold") @db.Decimal(12, 2)
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger WalletLedger[]

  @@map("wallets")
}

model UserDevice {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  deviceId    String   @unique @map("device_id")
  deviceInfo  String?  @map("device_info")
  lastLogin   DateTime @default(now()) @map("last_login")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_devices")
}

model WalletLedger {
  id        String   @id @default(uuid())
  walletId  String   @map("wallet_id")
  amount    Decimal  @db.Decimal(12, 2)
  type      String   // CREDIT | DEBIT
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@map("wallet_ledger")
}

model Product {
  id        String          @id @default(uuid())
  code      String          @unique
  name      String
  category  ProductCategory
  costPrice Decimal         @map("cost_price") @db.Decimal(12, 2)
  priceReseller    Decimal  @map("price_reseller") @db.Decimal(12, 2)
  skuH2h    String          @map("sku_h2h")
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")

  transactions Transaction[]

  @@map("products")
}

model Transaction {
  id           String            @id @default(uuid())
  userId       String            @map("user_id")
  productId    String            @map("product_id")
  targetNumber String            @map("target_number")
  customerName String?           @map("customer_name")
  costPrice    Decimal           @map("cost_price") @db.Decimal(12, 2)
  sellPrice    Decimal           @map("sell_price") @db.Decimal(12, 2)
  margin       Decimal           @db.Decimal(12, 2)
  pointsEarned Int               @default(0) @map("points_earned")
  refIdH2h     String?           @unique @map("ref_id_h2h")
  sn           String?
  status       TransactionStatus @default(PENDING)
  failReason   String?           @map("fail_reason")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("transactions")
}

model Deposit {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  amount      Decimal       @db.Decimal(12, 2)
  proofUrl    String?       @map("proof_url")
  note        String?
  adminNote   String?       @map("admin_note")
  method      String        @default("TRANSFER") // TRANSFER | QRIS | VA
  status      DepositStatus @default(PENDING)
  approvedBy  String?       @map("approved_by")
  approvedAt  DateTime?     @map("approved_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deposits")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model PointLedger {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  points    Int
  type      String   // EARN | REDEEM
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_ledger")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String   @map("image_url")
  linkUrl   String?  @map("link_url")
  isActive  Boolean  @default(true) @map("is_active")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banners")
}

model FavoriteNumber {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  label     String
  number    String
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("favorite_numbers")
}

model Catatan {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("catatan")
}

model KasirSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  items     Json     // array of { txId, productName, amount, targetNumber }
  total     Decimal  @db.Decimal(12,2)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kasir_sessions")
}
