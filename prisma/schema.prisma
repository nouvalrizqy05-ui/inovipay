generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  RESELLER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductCategory {
  PULSA
  DATA
  TOKEN_PLN
  PDAM
  GAME
  LAINNYA
}

enum NotificationType {
  TRANSACTION_SUCCESS
  TRANSACTION_FAILED
  DEPOSIT_APPROVED
  DEPOSIT_REJECTED
  LOW_BALANCE_ALERT
  SYSTEM
}

model User {
  id           String     @id @default(uuid())
  name         String
  phone        String     @unique
  email        String     @unique
  passwordHash String     @map("password_hash")
  pinHash      String?    @map("pin_hash")
  role         Role       @default(RESELLER)
  status       UserStatus @default(PENDING)
  resetToken   String?    @map("reset_token")
  resetTokenExp DateTime? @map("reset_token_exp")
  referralCode String?    @unique @map("referral_code")
  referredBy   String?    @map("referred_by")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  wallet        Wallet?
  transactions  Transaction[]
  deposits      Deposit[]
  notifications Notification[]

  @@map("users")
}

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  balanceHold Decimal  @default(0) @map("balance_hold") @db.Decimal(12, 2)
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User           @relation(fields: [userId], references: [id])
  transactions WalletLedger[]

  @@map("wallets")
}

model WalletLedger {
  id            String   @id @default(uuid())
  walletId      String   @map("wallet_id")
  transactionId String?  @map("transaction_id")
  depositId     String?  @map("deposit_id")
  amount        Decimal  @db.Decimal(12, 2)
  type          String   // "CREDIT" | "DEBIT"
  note          String?
  createdAt     DateTime @default(now()) @map("created_at")

  wallet      Wallet       @relation(fields: [walletId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])
  deposit     Deposit?     @relation(fields: [depositId], references: [id])

  @@map("wallet_ledger")
}

model Brand {
  id        String          @id @default(uuid())
  name      String
  slug      String          @unique
  logoUrl   String?         @map("logo_url")
  category  ProductCategory

  products  Product[]

  @@map("brands")
}

model Product {
  id           String          @id @default(uuid())
  code         String          @unique
  name         String
  category     ProductCategory
  brandId      String?         @map("brand_id")
  providerName String          @default("DIGIFLAZZ") @map("provider_name")
  costPrice    Decimal         @map("cost_price") @db.Decimal(12, 2)
  sellPrice    Decimal         @map("sell_price") @db.Decimal(12, 2)
  skuH2h       String          @map("sku_h2h")
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")

  brand        Brand?          @relation(fields: [brandId], references: [id])
  transactions Transaction[]

  @@map("products")
}

model Transaction {
  id                  String            @id @default(uuid())
  userId              String            @map("user_id")
  productId           String            @map("product_id")
  targetNumber        String            @map("target_number")
  targetZone          String?           @map("target_zone")
  costPrice           Decimal           @map("cost_price") @db.Decimal(12, 2)
  sellPrice           Decimal           @map("sell_price") @db.Decimal(12, 2)
  margin              Decimal           @db.Decimal(12, 2)
  refIdH2h            String?           @unique @map("ref_id_h2h")
  sn                  String?
  status              TransactionStatus @default(PENDING)
  failReason          String?           @map("fail_reason")
  providerCallbackRaw Json?             @map("provider_callback_raw")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id])
  product Product        @relation(fields: [productId], references: [id])
  ledgers WalletLedger[]

  @@map("transactions")
}

model Deposit {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  amount        Decimal       @db.Decimal(12, 2)
  uniqueCode    Int           @default(0) @map("unique_code")
  proofUrl      String?       @map("proof_url")
  note          String?
  adminNote     String?       @map("admin_note")
  status      DepositStatus @default(PENDING)
  approvedBy  String?       @map("approved_by")
  approvedAt  DateTime?     @map("approved_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id])
  ledgers WalletLedger[]

  @@map("deposits")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}
