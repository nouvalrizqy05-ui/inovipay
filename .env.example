# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/inovipay_db"
# Untuk Supabase:
# DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"
# DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ============================================
# JWT - Generate: openssl rand -base64 32
# ============================================
JWT_SECRET="ganti-dengan-random-string-minimal-32-karakter"

# ============================================
# DIGIFLAZZ API
# Dapatkan dari: digiflazz.com > Atur Koneksi > API
# ============================================
DIGIFLAZZ_USERNAME="username_digiflazz"
DIGIFLAZZ_API_KEY_DEV="dev-xxxx-xxxx-xxxx-xxxx"
DIGIFLAZZ_API_KEY_PROD="prod-xxxx-xxxx-xxxx-xxxx"

# ============================================
# ENVIRONMENT
# development = sandbox Digiflazz (transaksi tidak nyata)
# production  = API live Digiflazz
# ============================================
NODE_ENV="development"

# ============================================
# APP URL
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# ADMIN PERTAMA (dipakai saat npm run db:seed)
# ============================================
ADMIN_EMAIL="admin@inovipay.id"
ADMIN_PASSWORD="Admin123456!"
ADMIN_PHONE="081200000000"

# ============================================
# NOTIFIKASI WHATSAPP via Fonnte (OPSIONAL)
# Daftar di: fonnte.com
# Kalau kosong, notifikasi WA dinonaktifkan otomatis
# ============================================
# FONNTE_TOKEN="token_dari_fonnte"
