# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ppob_platform"

# ==========================================
# JWT — generate dengan: openssl rand -base64 32
# ==========================================
JWT_SECRET="ganti-dengan-random-string-panjang-minimal-32-karakter"

# ==========================================
# DIGIFLAZZ
# ==========================================
DIGIFLAZZ_USERNAME="username_digiflazz_kamu"
DIGIFLAZZ_API_KEY_DEV="api_key_sandbox_dari_dashboard_digiflazz"
DIGIFLAZZ_API_KEY_PROD="api_key_production_dari_dashboard_digiflazz"

# ==========================================
# ENVIRONMENT
# development = pakai sandbox Digiflazz
# production  = pakai API live Digiflazz
# ==========================================
NODE_ENV="development"

# ==========================================
# APP URL (untuk webhook callback)
# ==========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==========================================
# NOTIFIKASI WHATSAPP via Fonnte (opsional)
# Daftar di fonnte.com, isi token di sini
# ==========================================
# FONNTE_TOKEN="token_dari_fonnte"

# ==========================================
# SEED — akun admin pertama
# ==========================================
ADMIN_EMAIL="admin@ppob.com"
ADMIN_PASSWORD="ganti-password-admin-ini"
ADMIN_PHONE="081234567890"
